// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

// Tabela de Viagens
model Trip {
  id            String        @id @default(uuid())
  ownerId       String
  title         String
  
  imageUrl    String?  
  startDate   DateTime? 
  endDate     DateTime?

  description   String?
  status        String        @default("planning")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  participants String[] @default([])

  destinations Destination[]
}

// Tabela de Destinos/Paradas
model Destination {
  id        String     @id @default(uuid())
  name      String
  imageUrl  String?
  latitude  Float?
  longitude Float?
  order     Int        @default(0)

  startDate   DateTime? 
  endDate     DateTime?

  activities Activity[]

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId    String
  
  createdAt DateTime   @default(now())
}

// Tabela de Atividades
model Activity {
  id            String      @id @default(uuid())
  title         String
  type          String      // 'flight', 'hotel', 'restaurant', 'museum', etc.
  startTime     DateTime?   // Para sabermos que horas começa
  cost          Float?      @default(0)
  notes         String?
  
  // Relacionamento: Cada atividade pertence a um destino
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  destinationId String

  createdAt     DateTime    @default(now())
}